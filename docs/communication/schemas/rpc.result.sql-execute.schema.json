{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/rpc.result.sql-execute.v1.json",
  "title": "sql.execute result",
  "description": "Result payload for successful sql.execute responses. effective_max_rows reflects the negotiated row cap. Managed pagination is applied inside the agent; the executed SQL dialect depends on the configured ODBC driver (see socket_communication_standard.md).",
  "type": "object",
  "required": ["execution_id", "started_at", "finished_at", "rows", "row_count"],
  "properties": {
    "execution_id": { "type": "string" },
    "stream_id": { "type": "string" },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": { "type": "string", "format": "date-time" },
    "sql_handling_mode": {
      "type": "string",
      "enum": ["managed", "preserve"]
    },
    "max_rows_handling": {
      "type": "string",
      "enum": ["response_truncation"]
    },
    "effective_max_rows": {
      "type": "integer",
      "minimum": 1,
      "description": "The row limit actually applied after negotiation (min of request and transport limit)"
    },
    "rows": {
      "type": "array",
      "maxItems": 100000,
      "description": "Static hard ceiling. Effective per-request limit is `effective_max_rows` (negotiated).",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "row_count": { "type": "integer", "minimum": 0 },
    "returned_rows": { "type": "integer", "minimum": 0 },
    "affected_rows": { "type": "integer", "minimum": 0 },
    "truncated": { "type": "boolean" },
    "multi_result": { "type": "boolean" },
    "result_set_count": { "type": "integer", "minimum": 0 },
    "item_count": { "type": "integer", "minimum": 0 },
    "column_metadata": {
      "type": "array",
      "maxItems": 1024,
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "result_sets": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "required": ["index", "rows", "row_count"],
        "properties": {
          "index": { "type": "integer", "minimum": 0 },
          "rows": {
            "type": "array",
            "maxItems": 100000,
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "row_count": { "type": "integer", "minimum": 0 },
          "affected_rows": { "type": "integer", "minimum": 0 },
          "column_metadata": {
            "type": "array",
            "maxItems": 1024,
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": false
      }
    },
    "items": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "required": ["type", "index"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["result_set", "row_count"]
          },
          "index": { "type": "integer", "minimum": 0 },
          "result_set_index": { "type": "integer", "minimum": 0 },
          "rows": {
            "type": "array",
            "maxItems": 100000,
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "row_count": { "type": "integer", "minimum": 0 },
          "affected_rows": { "type": "integer", "minimum": 0 },
          "column_metadata": {
            "type": "array",
            "maxItems": 1024,
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": false
      }
    },
    "pagination": {
      "type": "object",
      "required": [
        "page",
        "page_size",
        "returned_rows",
        "has_next_page",
        "has_previous_page"
      ],
      "properties": {
        "page": { "type": "integer", "minimum": 1 },
        "page_size": { "type": "integer", "minimum": 1 },
        "returned_rows": { "type": "integer", "minimum": 0 },
        "has_next_page": { "type": "boolean" },
        "has_previous_page": { "type": "boolean" },
        "current_cursor": { "type": "string" },
        "next_cursor": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
