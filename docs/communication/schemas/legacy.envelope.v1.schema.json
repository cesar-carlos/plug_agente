{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/legacy.envelope.v1.json",
  "title": "Legacy Envelope v1",
  "description": "Legacy envelope protocol for query_request and query_response",
  "type": "object",
  "required": ["v", "type", "requestId", "agentId", "timestamp", "payloadBytes"],
  "properties": {
    "v": { "const": 1 },
    "type": {
      "type": "string",
      "enum": ["query_request", "query_response"]
    },
    "requestId": { "type": "string" },
    "agentId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "cmp": { "type": "string", "default": "none" },
    "contentType": { "type": "string", "default": "json" },
    "payloadBytes": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "For query_request: { query, parameters }. For query_response: array of row objects."
      }
    }
  }
}
