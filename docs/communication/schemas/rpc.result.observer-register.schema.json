{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/rpc.result.observer-register.v1.json",
  "title": "observer.register result",
  "type": "object",
  "required": ["observer_id", "interval_seconds", "condition", "created_at", "next_run_at"],
  "properties": {
    "observer_id": {
      "type": "string"
    },
    "interval_seconds": {
      "type": "integer",
      "minimum": 30,
      "maximum": 86400
    },
    "condition": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "const": "rows_present"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "next_run_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
