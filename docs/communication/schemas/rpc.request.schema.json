{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/rpc.request.v1.json",
  "title": "RPC Request",
  "description": "JSON-RPC 2.0 request with optional v2.1 extensions",
  "type": "object",
  "required": ["jsonrpc", "method"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "method": { "type": "string" },
    "id": { "type": ["string", "number", "null"] },
    "params": {},
    "api_version": { "type": "string" },
    "meta": {
      "type": "object",
      "properties": {
        "trace_id": { "type": "string" },
        "traceparent": { "type": "string" },
        "tracestate": { "type": "string" },
        "request_id": { "type": "string" },
        "agent_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "outbound_compression": {
          "type": "string",
          "enum": ["none", "gzip", "auto"],
          "description": "Optional override for agent->hub PayloadFrame compression policy for this request (and matching rpc:chunk/rpc:complete). When omitted, the agent uses its configured default."
        }
      }
    }
  }
}
