{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/rpc.error.v1.json",
  "title": "RPC Error",
  "description": "JSON-RPC 2.0 error with structured error.data fields",
  "type": "object",
  "required": ["code", "message"],
  "properties": {
    "code": { "type": "integer" },
    "message": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["reason", "category", "retryable", "user_message", "technical_message", "correlation_id", "timestamp"],
      "properties": {
        "reason": { "type": "string" },
        "category": { "type": "string" },
        "retryable": { "type": "boolean" },
        "user_message": { "type": "string" },
        "technical_message": { "type": "string" },
        "correlation_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}
