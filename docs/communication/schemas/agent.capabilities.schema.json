{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/agent.capabilities.v1.json",
  "title": "agent:capabilities payload",
  "type": "object",
  "required": ["capabilities"],
  "properties": {
    "capabilities": {
      "type": "object",
      "required": ["protocols", "encodings", "compressions", "extensions", "limits"],
      "properties": {
        "protocols": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "encodings": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "compressions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "extensions": { "type": "object" },
        "limits": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
