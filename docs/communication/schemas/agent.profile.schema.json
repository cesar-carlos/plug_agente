{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/agent.profile.v1.json",
  "title": "Agent profile payload",
  "type": "object",
  "required": [
    "name",
    "trade_name",
    "document",
    "document_type",
    "mobile",
    "email",
    "address"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "trade_name": { "type": "string", "minLength": 1, "maxLength": 100 },
    "document": { "type": "string", "minLength": 11, "maxLength": 14 },
    "document_type": { "type": "string", "enum": ["cpf", "cnpj"] },
    "phone": { "type": "string", "minLength": 10, "maxLength": 11 },
    "mobile": { "type": "string", "minLength": 11, "maxLength": 11 },
    "email": { "type": "string", "format": "email" },
    "address": {
      "type": "object",
      "required": [
        "street",
        "number",
        "district",
        "postal_code",
        "city",
        "state"
      ],
      "properties": {
        "street": { "type": "string", "minLength": 1, "maxLength": 100 },
        "number": { "type": "string", "minLength": 1, "maxLength": 15 },
        "district": { "type": "string", "minLength": 1, "maxLength": 60 },
        "postal_code": { "type": "string", "minLength": 8, "maxLength": 10 },
        "city": { "type": "string", "minLength": 1, "maxLength": 60 },
        "state": { "type": "string", "minLength": 2, "maxLength": 2 }
      },
      "additionalProperties": false
    },
    "notes": { "type": "string", "maxLength": 2000 }
  },
  "additionalProperties": false
}
