{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plugagente.dev/schemas/agent.register.v1.json",
  "title": "agent:register payload",
  "type": "object",
  "required": ["agentId", "timestamp", "capabilities"],
  "properties": {
    "agentId": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "profile": {
      "$ref": "./agent.profile.schema.json"
    },
    "profile_version": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional hub catalog profile version known by the agent for the included profile snapshot."
    },
    "profile_updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Optional hub profile timestamp known by the agent for the included profile snapshot."
    },
    "capabilities": {
      "type": "object",
      "required": ["protocols", "encodings", "compressions", "extensions", "limits"],
      "properties": {
        "protocols": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "encodings": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "compressions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "extensions": {
          "type": "object",
          "description": "Negotiated capability extensions. parallelBatchDispatch may be a boolean shorthand (enabled=true with agent defaults) or an object with enabled, maxConcurrency, mixedReadOnlyMethods, and selectOnlySqlExecute to opt into parallel read-only JSON-RPC batch dispatch when both sides support it."
        },
        "limits": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
