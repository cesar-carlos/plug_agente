AUTO_UPDATE_FEED_URL=https://raw.githubusercontent.com/cesar-carlos/plug_agente/main/appcast.xml
# Background polling interval (seconds). Minimum 3600; default 3600 if unset or invalid.
# AUTO_UPDATE_CHECK_INTERVAL_SECONDS=3600

# E2E / Live tests (copy to .env and enable only what you need)
# RUN_LIVE_API_TESTS=true
# API_TEST_BASE_URL=http://31.97.29.223:3000/
# API_TEST_TIMEOUT_URL=http://10.255.255.1:9999/

# SQL Anywhere / Sybase
# ODBC_TEST_DSN=DRIVER={SQL Anywhere 16};UID=dba;PWD=sql;DBN=VL;HOST=localhost:2650
# ODBC_DSN=DRIVER={SQL Anywhere 16};UID=dba;PWD=sql;DBN=VL;HOST=localhost:2650

# SQL Server
# ODBC_TEST_DSN_SQL_SERVER=DRIVER={ODBC Driver 17 for SQL Server};Server=localhost;Port=1433;Database=master;UID=sa;PWD=YourPassword
# ODBC_DSN_SQL_SERVER=DRIVER={ODBC Driver 17 for SQL Server};Server=localhost;Port=1433;Database=master;UID=sa;PWD=YourPassword

# PostgreSQL
# ODBC_TEST_DSN_POSTGRESQL=DRIVER={PostgreSQL Unicode};Server=localhost;Port=5432;Database=postgres;UID=postgres;PWD=YourPassword
# ODBC_DSN_POSTGRESQL=DRIVER={PostgreSQL Unicode};Server=localhost;Port=5432;Database=postgres;UID=postgres;PWD=YourPassword

# ODBC RPC live E2E (test/live/odbc_rpc_execute_live_e2e_test.dart)
# ODBC_E2E_REQUIRE_MULTI_RESULT=true
# ODBC_E2E_TRANSACTIONAL_BATCH=true

# ODBC RPC benchmark (test/live/odbc_rpc_benchmark_live_e2e_test.dart)
# ODBC_E2E_BENCHMARK=true
# ODBC_E2E_BENCHMARK_RECORD=true
# ODBC_E2E_BENCHMARK_FILE=benchmark/e2e_odbc_rpc.jsonl
# ODBC_E2E_BENCHMARK_DB_HOSTING=local
# ODBC_E2E_BENCHMARK_MATRIX=lease:2:4;lease:4:8;native:8:8
# (native pool size < concurrency is auto-raised to concurrency — see normalizeOdbcE2eBenchmarkProfilesForNativeWorker)
# ODBC_E2E_BENCHMARK_POOL_MODE=lease
# ODBC_E2E_BENCHMARK_POOL_SIZE=4
# ODBC_E2E_BENCHMARK_CONCURRENCY=8
# ODBC_E2E_BENCHMARK_SEED_ROWS=32
# ODBC_E2E_BENCHMARK_MAX_RESULT_BUFFER_MB=32
# ODBC_E2E_BENCHMARK_STREAMING_CHUNK_SIZE_KB=1024
# ODBC_E2E_BENCHMARK_LOGIN_TIMEOUT_SECONDS=30
# ODBC_E2E_BENCHMARK_REQUIRE_TIMEOUT_CANCEL=false
# ODBC_E2E_BENCHMARK_BASELINE_FILE=benchmark/e2e_odbc_rpc.jsonl
# ODBC_E2E_BENCHMARK_MAX_REGRESSION_PERCENT=15
# ODBC_E2E_BENCHMARK_MAX_REGRESSION_MS=0
# ODBC_E2E_BENCHMARK_BASELINE_WINDOW=5
# For stable ms gates on a dev machine: ODBC_E2E_BENCHMARK_MAX_REGRESSION_MS=2
# and/or: flutter test --profile test/live/odbc_rpc_benchmark_live_e2e_test.dart
# ODBC_E2E_BENCHMARK_MAX_MS_MATERIALIZED=800
# ODBC_E2E_BENCHMARK_MAX_MS_BATCH_READS=900
# ODBC_E2E_BENCHMARK_MAX_MS_NAMED_PARAMS=800
# ODBC_E2E_BENCHMARK_MAX_MS_MULTI_RESULT=900
# ODBC_E2E_BENCHMARK_MAX_MS_BATCH_TX=1000
# ODBC_E2E_BENCHMARK_MAX_MS_WRITE_DML=1000
# ODBC_E2E_BENCHMARK_MAX_MS_TIMEOUT_CANCEL=1500
# ODBC_E2E_BENCHMARK_MAX_MS_STREAMING=1200
# ODBC_E2E_BENCHMARK_MAX_MS_STREAMING_CHUNKS=1400
# ODBC_E2E_BENCHMARK_MAX_MS_MATERIALIZED_PARALLEL=2000
# ODBC_E2E_BENCHMARK_MAX_MS_BATCH_READS_PARALLEL=2500
# ODBC_E2E_BENCHMARK_MAX_MS_MULTI_RESULT_PARALLEL=2200
# ODBC_E2E_BENCHMARK_MAX_MS_WRITE_DML_PARALLEL=2200
# ODBC_E2E_BENCHMARK_MAX_MS_IDEMPOTENCY_HEAVY=2500
# ODBC_E2E_BENCHMARK_BATCH_COMMAND_COUNT=3
# ODBC_E2E_BENCHMARK_MATERIALIZED_MAX_ROWS=0
# ODBC_E2E_BENCHMARK_IDEMPOTENCY_WASTE_BYTES=0

# Socket transport codec benchmark (test/infrastructure/codecs/transport_pipeline_benchmark_test.dart)
# SOCKET_TRANSPORT_BENCHMARK=true
# SOCKET_TRANSPORT_BENCHMARK_RECORD=true
# SOCKET_TRANSPORT_BENCHMARK_FILE=benchmark/socket_transport.jsonl
# SOCKET_TRANSPORT_BENCHMARK_BASELINE_FILE=benchmark/socket_transport.jsonl
# SOCKET_TRANSPORT_BENCHMARK_MAX_REGRESSION_PERCENT=15
# SOCKET_TRANSPORT_BENCHMARK_MAX_REGRESSION_MS=8
# SOCKET_TRANSPORT_BENCHMARK_REQUIRE_BASELINE=false
# SOCKET_TRANSPORT_BENCHMARK_INCLUDE_JUMBO=false
# SOCKET_TRANSPORT_BENCHMARK_JUMBO_BLOB_BYTES=286720

# GZIP micro-benchmarks (read Platform.environment — pass via shell when running flutter test)
# CODEC_GZIP_BENCHMARK=true
# CODEC_GZIP_BENCHMARK_ITERATIONS=24
# CODEC_GZIP_BENCHMARK_PAYLOAD_KB=256
# GZIP_COMPRESSOR_BENCHMARK=true
# GZIP_COMPRESSOR_BENCHMARK_ITERATIONS=10
# GZIP_COMPRESSOR_BENCHMARK_SMALL_ROWS=24
# GZIP_COMPRESSOR_BENCHMARK_LARGE_ROWS=400
# GZIP_COMPRESSOR_BENCHMARK_LARGE_ROW_PAYLOAD_CHARS=48

# Socket transport E2E benchmark (test/infrastructure/external_services/socket_transport_e2e_benchmark_test.dart)
# SOCKET_TRANSPORT_E2E_BENCHMARK=true
# SOCKET_TRANSPORT_E2E_BENCHMARK_RECORD=true
# SOCKET_TRANSPORT_E2E_BENCHMARK_FILE=benchmark/socket_transport_e2e.jsonl
# SOCKET_TRANSPORT_E2E_BENCHMARK_ACK_FAILS=1
# SOCKET_TRANSPORT_E2E_BENCHMARK_BASELINE_FILE=benchmark/socket_transport_e2e.jsonl
# SOCKET_TRANSPORT_E2E_BENCHMARK_BASELINE_WINDOW=5
# SOCKET_TRANSPORT_E2E_BENCHMARK_MAX_REGRESSION_PERCENT=15
# SOCKET_TRANSPORT_E2E_BENCHMARK_MAX_REGRESSION_MS=2
# SOCKET_TRANSPORT_E2E_BENCHMARK_REQUIRE_BASELINE=false
# If streaming_backpressure flakes vs baseline in debug, try MAX_REGRESSION_MS=3
# SOCKET_TRANSPORT_E2E_BENCHMARK_MAX_MS_RPC_ROUNDTRIP=500
# SOCKET_TRANSPORT_E2E_BENCHMARK_MAX_MS_ACK_RETRY=700
# SOCKET_TRANSPORT_E2E_BENCHMARK_MAX_MS_STREAMING_BACKPRESSURE=1200
# SOCKET_TRANSPORT_E2E_BENCHMARK_STRICT_OUTGOING_CONTRACT=true

# PayloadFrame transport benchmark (test/infrastructure/codecs/payload_frame_transport_benchmark_test.dart)
# PAYLOAD_FRAME_BENCHMARK=true
# PAYLOAD_FRAME_BENCHMARK_RECORD=true
# PAYLOAD_FRAME_BENCHMARK_FILE=benchmark/payload_frame_transport.jsonl
# PAYLOAD_FRAME_BENCHMARK_BASELINE_FILE=benchmark/payload_frame_transport.jsonl
# PAYLOAD_FRAME_BENCHMARK_BASELINE_WINDOW=5
# PAYLOAD_FRAME_BENCHMARK_MAX_REGRESSION_PERCENT=10
# PAYLOAD_FRAME_BENCHMARK_MAX_REGRESSION_MS=5
# PAYLOAD_FRAME_BENCHMARK_REQUIRE_BASELINE=false
# PAYLOAD_FRAME_BENCHMARK_ITERATIONS=15
# PAYLOAD_FRAME_BENCHMARK_WARMUP=3

# RetryManager synthetic backoff (test/infrastructure/retry/retry_manager_benchmark_test.dart)
# RETRY_MANAGER_BENCHMARK=true
# RETRY_MANAGER_BENCHMARK_RECORD=true
# RETRY_MANAGER_BENCHMARK_FILE=benchmark/retry_manager.jsonl

# Idempotency fingerprint isolate path (test/application/rpc/idempotency_fingerprint_benchmark_test.dart)
# IDEMPOTENCY_FINGERPRINT_BENCHMARK=true
# IDEMPOTENCY_FINGERPRINT_BENCHMARK_RECORD=true
# IDEMPOTENCY_FINGERPRINT_BENCHMARK_FILE=benchmark/idempotency_fingerprint.jsonl
# IDEMPOTENCY_FINGERPRINT_BENCHMARK_WASTE_BYTES=307200
# IDEMPOTENCY_FINGERPRINT_BENCHMARK_ITERATIONS=12

# Authorization caches (optional; defaults 8192 / 2048)
# AUTH_DECISION_CACHE_MAX_ENTRIES=8192
# AUTH_POLICY_CACHE_MAX_ENTRIES=2048

# App preferences (reference keys only; not read from .env by default)
# feature_enable_per_request_outbound_compression=true
# feature_enable_socket_outbound_compression_debug_log=false

# ODBC smoke/long queries (optional)
# ODBC_INTEGRATION_SMOKE_QUERY=SELECT 1
# ODBC_INTEGRATION_LONG_QUERY_SQL_ANYWHERE=SELECT * FROM sys.systab
# ODBC_INTEGRATION_LONG_QUERY_SQL_SERVER=SELECT * FROM sys.tables
# ODBC_INTEGRATION_LONG_QUERY_POSTGRESQL=SELECT * FROM pg_tables
