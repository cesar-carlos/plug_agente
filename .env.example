# Official auto-update feed endpoint
AUTO_UPDATE_FEED_URL=https://cesar-carlos.github.io/plug_agente/appcast.xml
AUTO_UPDATE_CHECK_INTERVAL_SECONDS=3600
# stable e o canal de producao. Use beta/internal somente em builds de teste.
AUTO_UPDATE_CHANNEL=stable
# true por padrao; define false apenas em ambientes sem assinatura Authenticode configurada.
AUTO_UPDATE_REQUIRE_VALID_SIGNATURE=true
# Chave publica Ed25519 (base64) usada para verificar plug:edSignature.
# Distribuida pelo time de release; obrigatoria quando require_feed_signature=true.
# AUTO_UPDATE_FEED_PUBLIC_KEY=<base64-32-bytes>
# Quando true, rejeita items do appcast sem assinatura Ed25519 valida.
# Default false enquanto o pipeline de assinatura nao esta em todas as releases.
# AUTO_UPDATE_REQUIRE_FEED_SIGNATURE=false
# Timeout do download do instalador em segundos (min 60, padrao 300).
# AUTO_UPDATE_DOWNLOAD_TIMEOUT_SECONDS=300
# Tempo maximo de espera pelo helper de instalacao em minutos (min 5, max 120, padrao 30).
# Aumentar em maquinas lentas ou com antivirus pesado.
# AUTO_UPDATE_HELPER_WAIT_MINUTES=30

# E2E / Live Integration Tests (copie para .env e defina para rodar esses testes)
# RUN_LIVE_API_TESTS=true
# API_TEST_BASE_URL=http://31.97.29.223:3000/
# API_TEST_TIMEOUT_URL=http://10.255.255.1:9999/
# --- Hub live local (plug_server + e2e-dev) ---
# RUN_LIVE_HUB_TESTS=true
# RUN_LIVE_HUB_SIGNING_TESTS=true
# RUN_LIVE_HUB_AGENT_ACTION_RPC_TESTS=true
# E2E_HUB_URL=http://127.0.0.1:3000/agents
# E2E_HUB_TOKEN=
# PAYLOAD_SIGNING_KEY_ID=e2e-dev
# PAYLOAD_SIGNING_ACTIVE_KEY_ID=
# PAYLOAD_SIGNING_KEY=
# E2E_HUB_AGENT_ID=codex-live-agent
#
# --- Hub homologação remota (copiar PAYLOAD_SIGNING_* do deploy; não use e2e-dev) ---
# RUN_LIVE_HUB_TESTS=true
# RUN_LIVE_HUB_SIGNING_TESTS=true
# RUN_LIVE_HUB_AGENT_ACTION_RPC_TESTS=true
# E2E_HUB_URL=https://your-deployed-hub.example.com/agents
# E2E_HUB_TOKEN=
# PAYLOAD_SIGNING_KEY_ID=
# PAYLOAD_SIGNING_ACTIVE_KEY_ID=
# PAYLOAD_SIGNING_KEY=
# Opcional: tratar URL como Hub local para preflight (ex.: staging em LAN sem localhost no hostname)
# E2E_HUB_IS_LOCAL=true
# Opcional: só diagnóstico — permite testar e2e-dev contra URL remota (não use em CI)
# E2E_HUB_ALLOW_E2E_DEV_ON_REMOTE=true
# E2E_HUB_AGENT_ID=
# E2E_HUB_EXPECT_AGENT_ACTIONS_CAPABILITY=true — optional; assert extensions.agentActions in agent:capabilities
# E2E_HUB_EXPECT_AGENT_ACTION_RPC=true — optional; fails if hub does not send agent.action.* rpc:request after ready
#
# Hub Socket.IO + agent.action.* live E2E — preflight: dart run tool/validate_live_hub_agent_actions_env.dart
# Windows: dart run tool/suggest_e2e_hub_from_local_config.dart --apply-url
# Windows: dart run tool/fetch_e2e_hub_token_from_local_config.dart --apply-token
# Windows: dart run tool/sync_e2e_hub_env_from_local.dart --export-secure (after login + signing in app)
# RUN_EXPORT_E2E_SECRETS=true — only for export_e2e_secrets_from_secure_storage_test.dart
# E2E_HUB_USERNAME=  # optional: Hub agent login when app DB has no token (with E2E_HUB_PASSWORD)
# E2E_HUB_PASSWORD=
# Live Hub E2E: same id + secret on plug_server/.env. Dev pair: dart run tool/generate_dev_e2e_signing.dart --write
#
# Local gate (no Hub): .\tool\homologate_hub_agent_actions.ps1 -RunContractTests
# Preflight: dart run tool/preflight_agent_actions_production.dart
# Security PR checklist: dart run tool/agent_action_security_gate_checklist.dart [tipo]
# Live Hub: .\tool\homologate_hub_agent_actions.ps1 -ValidateLiveEnv -RunContractTests -RunLiveTests
# Rollback remoto (nao e .env): FeatureFlags em SharedPreferences — disableAgentActionsRemoteRollout(),
# maintenance mode, ou desligar enableAgentActions; ver plano gate §4195 / Riscos aceitos RA-08
# COM production handlers: lib/infrastructure/actions/com_object_production_registrations.dart
# COM homologation stub: AGENT_ACTION_COM_STUB_ENABLED=true (+ PROG_ID/MEMBER_NAME)

# SQL Anywhere / Sybase
# ODBC_TEST_DSN=DRIVER={SQL Anywhere 16};UID=dba;PWD=sql;DBN=VL;HOST=localhost:2650
# ODBC_DSN=DRIVER={SQL Anywhere 16};UID=dba;PWD=sql;DBN=VL;HOST=localhost:2650

# SQL Server
# ODBC_TEST_DSN_SQL_SERVER=DRIVER={ODBC Driver 17 for SQL Server};Server=localhost;Port=1433;Database=master;UID=sa;PWD=YourPassword
# ODBC_DSN_SQL_SERVER=DRIVER={ODBC Driver 17 for SQL Server};Server=localhost;Port=1433;Database=master;UID=sa;PWD=YourPassword

# PostgreSQL
# ODBC_TEST_DSN_POSTGRESQL=DRIVER={PostgreSQL Unicode};Server=localhost;Port=5432;Database=postgres;UID=postgres;PWD=YourPassword
# ODBC_DSN_POSTGRESQL=DRIVER={PostgreSQL Unicode};Server=localhost;Port=5432;Database=postgres;UID=postgres;PWD=YourPassword

# ODBC RPC E2E (odbc_rpc_execute_coverage_live_e2e_test) — opcional
# ODBC_E2E_RPC_DSN — opcional; se definido e não vazio, força o DSN só no E2E RPC (senão: fallback Anywhere → SQL Server → PostgreSQL)
# ODBC_E2E_REQUIRE_MULTI_RESULT=true — falha o teste se multi_result vier vazio após fallback
# ODBC_E2E_TRANSACTIONAL_BATCH=true — corre o teste opcional de sql.executeBatch com transaction: true
# DML performance E2E (odbc_dml_perf_live_e2e_test) — opcional; lote insert + update all + delete all
# ODBC_E2E_DML_PERF_TESTS=true
# ODBC_E2E_DML_PERF_ROW_COUNT=100
# ODBC_E2E_DML_PERF_MAX_MS_INSERT=60000 — opcional (falha se exceder)
# ODBC_E2E_DML_PERF_MAX_MS_UPDATE=60000
# ODBC_E2E_DML_PERF_MAX_MS_DELETE=60000
# DML carga massiva (odbc_dml_bulk_load_live_e2e_test) — opcional; 50k rows default, pode levar muitos minutos
# ODBC_E2E_DML_BULK_TESTS=true
# ODBC_E2E_DML_BULK_ROW_COUNT=50000
# ODBC_E2E_DML_BULK_CHUNK_SIZE=1000
# ODBC_E2E_DML_BULK_MAX_MS_INSERT=1800000 — opcional (30 min, exemplo)
# Lock / concorrência real (odbc_lock_contention_live_integration_test) — opcional, pode ser lento
# ODBC_RUN_LOCK_CONTENTION_TESTS=true
# Burst da fila SQL (sql_queue_burst_test) — 50 pedidos paralelos; precisa DSN RPC + query longa (ver docs/testing/e2e_setup.md)
# RUN_ODBC_BURST_TESTS=true

# RPC idempotency cache (Drift sqlite; enableSocketIdempotency)
# RPC_IDEMPOTENCY_CACHE_TTL_SECONDS=300 — sql.execute/batch/bulkInsert (60..86400, default 300)
# AGENT_OPERATIONAL_PROFILE — optional agent profile for action environment policy (dev, homolog, prod, etc.)
# AGENT_ACTION_RPC_IDEMPOTENCY_CACHE_TTL_SECONDS — agent.action.run/validateRun (60..259200; default min(execution retention, 24h))
# AGENT_ACTION_EXECUTION_RETENTION_DAYS=3 — terminal execution history retention (1..3650 days)
# AGENT_ACTION_REMOTE_AUDIT_RETENTION_DAYS=90 — remote agent.action audit retention (7..3650 days)
# AGENT_ACTION_CAPTURED_OUTPUT_RETENTION_HOURS=24 — stdout/stderr column clear on old terminal rows (1..720h; capped by history retention)
# UI (Acoes → Retencao de dados) can persist overrides in IAppSettingsStore; they take precedence over env for this install.
# Agent action policy ceilings (per-definition values must be at or below these on save; also advertised in agent:capabilities)
# AGENT_ACTION_MAX_CONCURRENT=1
# AGENT_ACTION_MAX_QUEUED=100
# AGENT_ACTION_QUEUE_TIMEOUT_SECONDS=300
# AGENT_ACTION_MAX_RUNTIME_SECONDS=1800
# AGENT_ACTION_MAX_RETRIES=1
# AGENT_ACTION_MAX_CONTEXT_BYTES=262144
# AGENT_ACTION_MAX_CAPTURED_OUTPUT_BYTES=65536
# AGENT_ACTION_COM_STUB_ENABLED=true — homologation only: register ComObjectStubInvocationHandler in DI
# AGENT_ACTION_COM_STUB_PROG_ID=AgentAction.Test
# AGENT_ACTION_COM_STUB_MEMBER_NAME=Ping

# Authorization caches — LRU max entries (opcional; padroes 8192 / 2048)
# AUTH_DECISION_CACHE_MAX_ENTRIES=8192
# AUTH_POLICY_CACHE_MAX_ENTRIES=2048

# SQL Anywhere TOP/START AT (odbc_sql_anywhere_top_start_at_live_test) — requer ODBC_TEST_DSN/ODBC_DSN
# ODBC_SQL_ANYWHERE_TOP_START_AT_QUERY=

# ODBC smoke/long queries (opcional; usados por odbc_streaming_* e cálculo de odbcLongQuery)
# ODBC_INTEGRATION_SMOKE_QUERY=SELECT 1
# ODBC_INTEGRATION_LONG_QUERY= — alternativa genérica se não preencher as específicas por motor abaixo
# Query longa para teste de cancelamento (muitas linhas ou lenta, por motor)
# ODBC_INTEGRATION_LONG_QUERY_SQL_ANYWHERE=SELECT * FROM sys.systab
# ODBC_INTEGRATION_LONG_QUERY_SQL_SERVER=SELECT * FROM sys.tables
# ODBC_INTEGRATION_LONG_QUERY_POSTGRESQL=SELECT * FROM pg_tables

# --- Hub Socket.IO (transport pipeline tuning) ---
#
# Isolate thresholds: heavy CPU work (gzip, HMAC-SHA256 signing) is offloaded to
# a background isolate when payload/frame size exceeds these limits.
#
# TRANSPORT_GZIP_ISOLATE_THRESHOLD_BYTES=32768
#   Payload size (original bytes) above which GZIP compress/decompress runs via
#   compute(). Below this, it runs on the main isolate. Default: 32768 (32 KiB).
#   Benchmark: dart run tool/benchmark_transport_pipeline.dart --gzip-isolate-threshold-sweep 16384,32768,65536
#
# TRANSPORT_SIGNING_ISOLATE_THRESHOLD_BYTES=65536
#   Frame original size above which HMAC-SHA256 signing/verification is offloaded
#   via compute(). Below this, canonicalization + HMAC run on the main isolate.
#   Relevant only when enablePayloadSigning is on. Default: 65536 (64 KiB).
#
# These FEATURE FLAGS live in SharedPreferences, not as .env keys.
# Enable in the app UI (Config → WebSocket) or set via app prefs before rollout.
#
# --- Parallel batch dispatch (default ON) ---
#   feature_enable_parallel_json_rpc_batch_dispatch=true  [default: true]
#   Dispatches read-only sql.execute SELECT items in a batch concurrently.
#   Gated by hub capabilities negotiation (hub must also advertise support).
#   Uses a pool-aware semaphore; safe to keep on for all production deployments.
#   Disable only if the hub does not advertise parallelBatchDispatch in capabilities
#   or if ODBC connections are severely limited.
#   feature_enable_parallel_json_rpc_batch_dispatch=false  ← rollback
#
# --- Streaming chunks + backpressure (default OFF; requires hub support) ---
#   Prerequisite: hub must negotiate streamingResults=true in agent:capabilities.
#   Pair all three for large ODBC result sets (> streaming_row_threshold rows).
#
#   feature_enable_socket_streaming_from_db=true   [default: true]  ← already on
#   feature_enable_socket_streaming_chunks=true    [default: false] → send rpc:chunk + rpc:complete
#   feature_enable_socket_backpressure=true        [default: false] → respect rpc:stream.pull credits
#
#   Without backpressure: chunks are emitted as fast as the ODBC stream produces them.
#   With backpressure: hub sends rpc:stream.pull to grant window_size per credit.
#   Buffer overflow (no pull received) → -32105 resultTooLarge / backpressure_overflow.
#
# --- Delivery guarantees (default OFF; increases ack traffic) ---
#   feature_enable_socket_delivery_guarantees=true  [default: false]
#   Agent emits rpc:request_ack (before dispatch) and rpc:batch_ack on batch receipt.
#   Agent retries rpc:response with emitWithAck up to 3 times on ack timeout.
#   Pair with hub-side retry + enableSocketIdempotency to prevent double execution.
#   Only enable when hub is configured to expect acks; otherwise the hub may not send them.

# --- Performance & Reliability Tuning ---
#
# ODBC connection pool size (default: 4)
# ODBC_POOL_SIZE=4
#
# Native pool (connection reuse) — enabled by default for SQL Server and PostgreSQL.
# SQL Anywhere always uses the lease pool (connect/disconnect per query) because
# some SQL Anywhere ODBC drivers return invalid handles under the native pool.
# Toggle in app UI (Config → Feature Flags → Adaptive ODBC Pooling) or via
# SharedPreferences key: feature_enable_odbc_experimental_driver_adaptive_pooling
#
# Direct connection concurrency for streaming queries (default: poolSize / 2).
# Streaming opens a dedicated connection outside the pool; this caps how many
# concurrent streams run alongside pooled RPC queries.
# ODBC_DIRECT_CONNECTION_MAX_CONCURRENT=2
#
# odbc_fast async worker pool.
# Default: worker = min(ODBC_POOL_SIZE, CPU cores).
# Default: pending = max(ODBC_POOL_SIZE * 4, SQL_QUEUE_MAX_WORKERS).
# Raising SQL_QUEUE_MAX_WORKERS above the default automatically lifts the
# pending limit to match, preventing premature failFast rejects.
# ODBC_ASYNC_WORKER_COUNT=4
# ODBC_ASYNC_MAX_PENDING_REQUESTS=16
#
# ODBC result encoding for parameterized queries (default: rowMajor).
# Values: rowMajor, columnar, columnarCompressed.
# columnarCompressed can reduce throughput latency on SQL Server for
# wide/read-heavy result sets. Validate with a workload-specific benchmark
# before changing; row-major is the safest default for all drivers.
# ODBC_RESULT_ENCODING=rowMajor

# SQL execution queue configuration
# SQL_QUEUE_MAX_SIZE=50        # Maximum queued requests (default: 50)
# SQL_QUEUE_MAX_WORKERS=4      # Concurrent SQL workers (default: same as ODBC_POOL_SIZE)
# SQL_QUEUE_TIMEOUT_SEC=5      # Queue wait timeout in seconds (default: 5)

# Circuit breaker for failing connections
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=5   # Failures before opening circuit (default: 5)
# CIRCUIT_BREAKER_RESET_SEC=30          # Seconds before trying half-open (default: 30)

# Recommended configurations by load:
# Light load (< 10 req/s):    ODBC_POOL_SIZE=4,  SQL_QUEUE_MAX_SIZE=20
# Medium load (10-50 req/s):  ODBC_POOL_SIZE=8,  SQL_QUEUE_MAX_SIZE=50
# Heavy load (> 50 req/s):    ODBC_POOL_SIZE=16, SQL_QUEUE_MAX_SIZE=100
# Note: ODBC_ASYNC_MAX_PENDING_REQUESTS is auto-scaled; override only if needed.

# --- Benchmarks / regressão (NÃO usam o helper E2EEnv) ---
# Lidos por `test/live/*` e testes *benchmark* (ex.: ODBC_E2E_BENCHMARK_*, SOCKET_TRANSPORT_BENCHMARK_*).
# Defina no teu .env local se correres esses ficheiros; ver comentários no topo de cada teste.
# Worker pool async: rode .\tool\odbc_async_benchmark.ps1 para comparar tuning ODBC local.

# Elevated action runner helper (Fase 5) — optional path when not colocated with plug_agente.exe
# Build helper: .\tool\build_elevated_runner.ps1  ->  build\elevated_runner\plug_agente_elevated_runner.exe
# ELEVATED_ACTION_RUNNER_EXE=C:\path\to\plug_agente_elevated_runner.exe
# Elevated runs: enable in app Feature Flags (enableElevatedAgentActions); requires helper install on Windows (see e2e_setup.md)
