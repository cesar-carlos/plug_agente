AUTO_UPDATE_FEED_URL=https://raw.githubusercontent.com/cesar-carlos/plug_agente/main/appcast.xml

# E2E / Live tests em test/live/ (copie para .env e defina para rodar esses testes)
# RUN_LIVE_API_TESTS=true
# API_TEST_BASE_URL=http://31.97.29.223:3000/
# API_TEST_TIMEOUT_URL=http://10.255.255.1:9999/

# SQL Anywhere / Sybase
# ODBC_TEST_DSN=DRIVER={SQL Anywhere 16};UID=dba;PWD=sql;DBN=VL;HOST=localhost:2650
# ODBC_DSN=DRIVER={SQL Anywhere 16};UID=dba;PWD=sql;DBN=VL;HOST=localhost:2650

# SQL Server
# ODBC_TEST_DSN_SQL_SERVER=DRIVER={ODBC Driver 17 for SQL Server};Server=localhost;Port=1433;Database=master;UID=sa;PWD=YourPassword
# ODBC_DSN_SQL_SERVER=DRIVER={ODBC Driver 17 for SQL Server};Server=localhost;Port=1433;Database=master;UID=sa;PWD=YourPassword

# PostgreSQL
# ODBC_TEST_DSN_POSTGRESQL=DRIVER={PostgreSQL Unicode};Server=localhost;Port=5432;Database=postgres;UID=postgres;PWD=YourPassword
# ODBC_DSN_POSTGRESQL=DRIVER={PostgreSQL Unicode};Server=localhost;Port=5432;Database=postgres;UID=postgres;PWD=YourPassword

# ODBC RPC live E2E (odbc_rpc_execute_live_e2e_test) — um grupo por DSN distinto (primary / sql_server / postgresql)
# ODBC_E2E_REQUIRE_MULTI_RESULT=true — falha o E2E RPC e o benchmark ODBC se multi_result (probe) vier sem result_sets/linhas
# ODBC_E2E_TRANSACTIONAL_BATCH=true — corre o 4.º teste: sql.executeBatch com transaction: true

# Benchmark ODBC RPC (odbc_rpc_benchmark_live_e2e_test) — mede latência e opcionalmente grava JSONL em benchmark/
# Ver benchmark/README.md e docs/testing/e2e_setup.md
# ODBC_E2E_BENCHMARK=true
# ODBC_E2E_BENCHMARK_RECORD=true — anexa uma linha JSON por DSN alvo (histórico local)
# ODBC_E2E_BENCHMARK_FILE=benchmark/e2e_odbc_rpc.jsonl — opcional; caminho do JSONL
# ODBC_E2E_BENCHMARK_DB_HOSTING=local — ou remote; metadado opcional no JSONL
# Regressão opcional (ms), por caso: MATERIALIZED, BATCH_READS, NAMED_PARAMS, MULTI_RESULT, BATCH_TX, STREAMING
# ODBC_E2E_BENCHMARK_MAX_MS_MATERIALIZED=800

# Authorization caches — LRU max entries (opcional; padroes 8192 / 2048)
# AUTH_DECISION_CACHE_MAX_ENTRIES=8192
# AUTH_POLICY_CACHE_MAX_ENTRIES=2048

# Preferências da app (SharedPreferences / IAppSettingsStore) — chaves para
# referência; não são lidas do .env por defeito. Úteis para documentação ou
# ferramentas que escrevam prefs diretamente.
# feature_enable_per_request_outbound_compression=true
# feature_enable_socket_outbound_compression_debug_log=false

# ODBC smoke/long queries (opcional)
# ODBC_INTEGRATION_SMOKE_QUERY=SELECT 1
# Query longa para teste de cancelamento (deve retornar muitas linhas ou demorar)
# ODBC_INTEGRATION_LONG_QUERY_SQL_ANYWHERE=SELECT * FROM sys.systab
# ODBC_INTEGRATION_LONG_QUERY_SQL_ANYWHERE=SELECT * FROM sys.systab
# ODBC_INTEGRATION_LONG_QUERY_SQL_SERVER=SELECT * FROM sys.tables
# ODBC_INTEGRATION_LONG_QUERY_POSTGRESQL=SELECT * FROM pg_tables
